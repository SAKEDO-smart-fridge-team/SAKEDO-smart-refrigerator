# MongoDB
MONGODB_URL="mongodb+srv://<db_user>:<db_password>@<cluster-host>/?appName=Sakedo"

# Google OAuth Client ID (Web application)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Frontend URL used in reset-password links
FRONTEND_BASE_URL="http://127.0.0.1:5501"

# SMTP config (example: Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="your-email@gmail.com"
SMTP_FROM_NAME="Sakedo Smart Fridge"
SMTP_USE_TLS="true"

# true: return reset_url in API response for local testing
# false: only return generic success message (recommended for production)
PASSWORD_RESET_RETURN_LINK="false"
